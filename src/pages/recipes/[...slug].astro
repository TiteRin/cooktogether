---
import Layout from '../../layouts/Layout.astro';
import RecipeDetail from '../../features/RecipeDetail';
import { loadRecipe } from '../../lib/recipeLoader';
import { findRecipes } from '../../lib/recipeDiscovery';
import path from 'node:path';

export async function getStaticPaths() {
  const recipesDir = path.resolve('./recipes');
  const recipes = await findRecipes(recipesDir);
  
  return recipes.map(recipe => {
    const slug = recipe.path.replace('.cook', '');
    return {
      params: { 
        slug: slug 
      },
      props: { 
        recipePath: path.join(recipesDir, recipe.path) 
      }
    };
  });
}

const { slug } = Astro.params;
const { recipePath } = Astro.props;

let recipe;
try {
  recipe = loadRecipe(recipePath);
} catch (e) {
  return Astro.redirect('/404');
}

console.log(recipe);
---

<Layout title={`${recipe.metadata.title || 'Recette'} — CookTogether`}>
  <main class="py-10">
    <div class="max-w-4xl mx-auto px-6 mb-6">
      <a href="/recipes" class="text-blue-600 hover:underline">← Retour aux recettes</a>
    </div>
    <RecipeDetail recipe={recipe} recipeId={slug} client:load />
  </main>
</Layout>
